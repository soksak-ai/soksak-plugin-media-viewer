{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-media-viewer",
  "name": {
    "ko": "\ubbf8\ub514\uc5b4 \ubdf0\uc5b4",
    "en": "Media Viewer"
  },
  "version": "0.0.1",
  "description": {
    "ko": "\uc774\ubbf8\uc9c0\u00b7PDF\u00b7\uc601\uc0c1\u00b7\uc624\ub514\uc624 \ud30c\uc77c\uc744 \ucf58\ud150\uce20\ub85c \ud45c\uc2dc\ud558\ub294 \ubdf0\uc5b4. soksak \ud30c\uc77c \ubdf0\uc5b4\ub85c \ub4f1\ub85d(\ucf54\uc5b4\uac00 \ud655\uc7a5\uc790\ub85c \ub77c\uc6b0\ud305).",
    "en": "Viewers for image, PDF, video, and audio files. Registers as soksak file viewers (the core routes by extension)."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "fs:read",
    "commands"
  ],
  "contributes": {
    "fileViewers": [
      {
        "id": "image",
        "extensions": [
          "png",
          "jpg",
          "jpeg",
          "gif",
          "webp",
          "bmp",
          "ico",
          "avif",
          "apng"
        ],
        "priority": 10
      },
      {
        "id": "pdf",
        "extensions": [
          "pdf"
        ],
        "priority": 10
      },
      {
        "id": "video",
        "extensions": [
          "mp4",
          "webm",
          "mov",
          "m4v",
          "ogv",
          "mkv"
        ],
        "priority": 10
      },
      {
        "id": "audio",
        "extensions": [
          "mp3",
          "wav",
          "ogg",
          "flac",
          "m4a",
          "aac"
        ],
        "priority": 10
      }
    ],
    "commands": [
      {
        "name": "viewers",
        "title": {
          "ko": "\ud30c\uc77c \ubdf0\uc5b4 \ubaa9\ub85d \uc870\ud68c",
          "en": "List file viewers"
        }
      },
      {
        "name": "classify",
        "title": {
          "ko": "\ud30c\uc77c \ubdf0\uc5b4 \ud310\ubcc4",
          "en": "Classify a file to its viewer"
        }
      }
    ]
  }
}
