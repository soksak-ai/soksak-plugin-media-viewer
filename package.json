{
  "name": "soksak-plugin-media-viewer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "soksak media-viewer plugin — image/pdf/video/audio file viewers",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "doctor": "soksak-plugin-doctor",
    "test": "node --test",
    "prepublishOnly": "npm run build && npm run doctor",
    "test-unit": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "esbuild": "^0.24.2",
    "typescript": "~5.9.3",
    "vitest": "^2.1.8",
    "soksak-plugin-doctor": "github:soksak-ai/soksak-plugin-doctor"
  }
}
